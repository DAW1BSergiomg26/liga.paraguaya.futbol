# Copia este archivo como .env y llena los valores
# cp .env.example .env

# URL de Neon (produccion) - SIN ?sslmode= en la URL
# Ejemplo: postgresql://neondb_owner:xxx@ep-xxx.us-east-2.aws.neon.tech/liga
PROD_DATABASE_URL=

# URL de PostgreSQL local (Docker) - ya configurada por defecto
LOCAL_DATABASE_URL=postgresql://liga:liga_password@localhost:5432/liga
