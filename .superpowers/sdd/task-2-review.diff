diff --git a/frontend/src/App.css b/frontend/src/App.css
new file mode 100644
index 0000000..c729233
--- /dev/null
+++ b/frontend/src/App.css
@@ -0,0 +1,160 @@
+´╗┐:root {
+  color: #f8fafc;
+  background: #07111f;
+  font-family: Inter, system-ui, Arial, sans-serif;
+}
+
+body {
+  margin: 0;
+  min-width: 320px;
+  min-height: 100vh;
+  background:
+    radial-gradient(circle at top left, rgba(0, 117, 255, 0.25), transparent 32rem),
+    radial-gradient(circle at top right, rgba(214, 31, 38, 0.22), transparent 28rem),
+    #07111f;
+}
+
+button,
+input,
+select,
+textarea {
+  font: inherit;
+}
+
+.app {
+  width: min(1180px, calc(100% - 32px));
+  margin: 0 auto;
+  padding: 48px 0;
+}
+
+.hero {
+  padding: 48px;
+  border: 1px solid rgba(255, 255, 255, 0.12);
+  border-radius: 28px;
+  background: rgba(8, 18, 33, 0.82);
+  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
+}
+
+.eyebrow {
+  margin: 0 0 12px;
+  color: #76e4f7;
+  font-weight: 700;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+h1 {
+  margin: 0;
+  font-size: clamp(2.4rem, 6vw, 5rem);
+  line-height: 0.95;
+}
+
+.heroText {
+  max-width: 720px;
+  margin: 24px 0;
+  color: #cbd5e1;
+  font-size: 1.15rem;
+}
+
+.status {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+  padding: 10px 14px;
+  border-radius: 999px;
+  background: rgba(16, 185, 129, 0.12);
+  color: #bbf7d0;
+  border: 1px solid rgba(74, 222, 128, 0.25);
+}
+
+.dot {
+  width: 10px;
+  height: 10px;
+  border-radius: 999px;
+  background: #22c55e;
+  box-shadow: 0 0 18px #22c55e;
+}
+
+.grid {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 24px;
+  margin-top: 24px;
+}
+
+.card {
+  padding: 28px;
+  border-radius: 24px;
+  background: rgba(15, 23, 42, 0.86);
+  border: 1px solid rgba(255, 255, 255, 0.1);
+}
+
+.card h2 {
+  margin-top: 0;
+  font-size: 1.6rem;
+}
+
+.cardsList {
+  display: grid;
+  gap: 14px;
+}
+
+.miniCard {
+  padding: 16px;
+  border-radius: 18px;
+  background: rgba(255, 255, 255, 0.055);
+  border: 1px solid rgba(255, 255, 255, 0.08);
+}
+
+.miniCard h3 {
+  margin: 0 0 8px;
+}
+
+.miniCard p {
+  margin: 0 0 8px;
+  color: #facc15;
+}
+
+.miniCard small {
+  color: #cbd5e1;
+}
+
+.tableCard {
+  margin-top: 24px;
+}
+
+.tableWrap {
+  overflow-x: auto;
+}
+
+table {
+  width: 100%;
+  border-collapse: collapse;
+}
+
+th,
+td {
+  padding: 14px 12px;
+  text-align: left;
+  border-bottom: 1px solid rgba(255, 255, 255, 0.09);
+}
+
+th {
+  color: #93c5fd;
+  font-size: 0.9rem;
+  text-transform: uppercase;
+}
+
+td {
+  color: #e5e7eb;
+}
+
+@media (max-width: 780px) {
+  .hero {
+    padding: 28px;
+  }
+
+  .grid {
+    grid-template-columns: 1fr;
+  }
+}
