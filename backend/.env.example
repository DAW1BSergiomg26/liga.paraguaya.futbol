# =============================================================================
# backend/.env.example — Variables de entorno del backend (liga.paraguaya.futbol)
# -----------------------------------------------------------------------------
# Copiar este archivo a `.env` (en local) o usar los MISMOS nombres en el
# dashboard de Koyeb / Render. NO commitear el `.env` real (con valores).
# Todos los nombres aqui coinciden exactamente con backend/app/core/config.py.
# =============================================================================

# --- Base de datos -----------------------------------------------------------
# OBLIGATORIA en produccion (Koyeb + Neon Postgres).
# Formato Neon: postgresql://USUARIO:PASSWORD@HOST/DB?sslmode=require
# El codigo acepta "postgres://" y lo convierte a "postgresql+asyncpg://".
# Si NO se setea, el backend usa SQLite local (se pierde al reiniciar el contenedor).
DATABASE_URL=

# --- CORS (orígenes permitidos del frontend) --------------------------------
# Lista separada por comas. Incluir SIEMPRE el dominio de Vercel.
CORS_ORIGINS=http://localhost:3000,https://frontend-ten-swart-85.vercel.app

# --- API key de administración (para rutas /api/v1/admin/*) ------------------
# OBLIGATORIA. Usala en el header X-API-Key. CAMBIALA por un valor seguro.
ADMIN_API_KEY=

# --- API de fútbol externa (opcional) ---------------------------------------
# Si esta vacía, el sync_loop de datos externos queda desactivado (no rompe).
FOOTBALL_DATA_API_KEY=

# --- JWT (autenticación de usuarios) ----------------------------------------
# OBLIGATORIA en produccion. Clave secreta para firmar tokens. CAMBIALA.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# --- Notificaciones push (Web Push) — OPCIONAL -------------------------------
# Si están vacías, las notificaciones push no funcionan (no rompe el resto).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=admin@ligapy.app

# --- Puerto (lo inyecta Koyeb/Railway en runtime) ----------------------------
# No suele setearse manualmente; el Dockerfile usa ${PORT:-8001}.
PORT=8001

# --- Debug -------------------------------------------------------------------
# En produccion dejar en false.
DEBUG=false
