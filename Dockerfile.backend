FROM python:3.12-slim

WORKDIR /app

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

ARG CACHE_BUST=1
COPY . .

# Download tiny LLM model for Cerezo Digital
RUN mkdir -p /app/backend/models && \
    if [ -f /app/backend/requirements.txt ] && grep -q "llama-cpp-python" /app/backend/requirements.txt; then \
        echo "Downloading Cerezo LLM model..." && \
        pip install huggingface-hub && \
        python -c "from huggingface_hub import hf_hub_download; hf_hub_download(repo_id='unsloth/Llama-3.2-1B-Instruct-GGUF', filename='Llama-3.2-1B-Instruct-Q4_K_M.gguf', local_dir='/app/backend/models')" && \
        echo "Model downloaded successfully"; \
    else \
        echo "llama-cpp-python not installed, skipping model download"; \
    fi

EXPOSE 8001

CMD uvicorn backend.app.main:app --host 0.0.0.0 --port ${PORT:-8001}
